---
---
<div id="custom-cursor" class="custom-cursor"></div>
<div id="custom-cursor-dot" class="custom-cursor-dot"></div>

<style>
  @media (pointer: fine) {
    body, a, button, input, textarea, select, [role="button"] {
      cursor: none !important;
    }

    .custom-cursor {
      position: fixed;
      top: 0;
      left: 0;
      width: 32px;
      height: 32px;
      border: 1px solid rgba(249, 115, 22, 0.5); /* tailwind orange-500 equivalent */
      border-radius: 50%;
      pointer-events: none;
      z-index: 9999;
      transform: translate3d(-50%, -50%, 0);
      transition: width 0.2s ease-out, height 0.2s ease-out, background-color 0.2s ease-out, border-color 0.2s ease-out;
      will-change: transform, width, height;
    }

    .custom-cursor-dot {
      position: fixed;
      top: 0;
      left: 0;
      width: 8px;
      height: 8px;
      background-color: #f97316; /* solid orange */
      border-radius: 50%;
      pointer-events: none;
      z-index: 10000;
      transform: translate3d(-50%, -50%, 0);
      will-change: transform;
    }

    .custom-cursor.hover {
      width: 48px;
      height: 48px;
      background-color: rgba(249, 115, 22, 0.15);
      border-color: rgba(249, 115, 22, 0.8);
    }
  }

  @media (pointer: coarse) {
    .custom-cursor, .custom-cursor-dot {
      display: none !important;
    }
  }
</style>

<script>
  const updateCursor = () => {
    const cursor = document.getElementById('custom-cursor');
    const cursorDot = document.getElementById('custom-cursor-dot');
    
    if (cursor && cursorDot && matchMedia('(pointer: fine)').matches) {
      let mouseX = window.innerWidth / 2;
      let mouseY = window.innerHeight / 2;
      let cursorX = mouseX;
      let cursorY = mouseY;
      let isAnimating = true;

      // smooth trailing effect for the larger circle
      const animate = () => {
        if (!isAnimating) return;
        cursorX += (mouseX - cursorX) * 0.2;
        cursorY += (mouseY - cursorY) * 0.2;
        
        const isHover = cursor.classList.contains('hover');
        const sizeOffset = isHover ? 24 : 16;
        
        cursor.style.transform = `translate3d(${cursorX - sizeOffset}px, ${cursorY - sizeOffset}px, 0)`;
        cursorDot.style.transform = `translate3d(${mouseX - 4}px, ${mouseY - 4}px, 0)`;
        
        requestAnimationFrame(animate);
      };
      
      requestAnimationFrame(animate);

      const moveHandler = (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
      };
      
      window.addEventListener('mousemove', moveHandler);

      const interactiveElements = document.querySelectorAll('a, button, input, textarea, select, [role="button"], .interactive, [data-framer-reveal]');
      
      const enterHandler = () => cursor.classList.add('hover');
      const leaveHandler = () => cursor.classList.remove('hover');

      interactiveElements.forEach(el => {
        if (!el.hasAttribute('data-cursor-attached')) {
          el.setAttribute('data-cursor-attached', 'true');
          el.addEventListener('mouseenter', enterHandler);
          el.addEventListener('mouseleave', leaveHandler);
        }
      });
      
      // Cleanup for hot module replacement / page transitions
      document.addEventListener('astro:before-preparation', () => {
        isAnimating = false;
        window.removeEventListener('mousemove', moveHandler);
      }, { once: true });
    }
  };

  updateCursor();
  document.addEventListener("astro:page-load", updateCursor);
</script>
