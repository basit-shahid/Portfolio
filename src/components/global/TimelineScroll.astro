---
export interface Section {
  id: string;
  label: string;
}

interface Props {
  sections: Section[];
}

const { sections } = Astro.props;
---

<nav id="timeline-scroll" aria-label="Page scroll progress">
  <div class="rail-track" id="rail-track">
    <div class="rail-line"></div>
    <div class="rail-fill" id="rail-fill"></div>
    <div class="rail-traveler" id="rail-traveler">
      <span class="traveler-glow"></span>
      <span class="traveler-core"></span>
    </div>

    {sections.map((section) => (
      <button
        class="rail-tick"
        data-target={section.id}
        aria-label={section.label}
        type="button"
      ></button>
    ))}
  </div>
</nav>

<style>
  #timeline-scroll {
    position: fixed;
    /* Pushed further right, closer to the true viewport edge */
    right: max(0.75rem, calc((100vw - 80rem) / 2 - 1.25rem));
    top: 50%;
    transform: translateY(-50%);
    z-index: 999;
    display: none;
    height: 68vh;
    max-height: 700px;
  }

  @media (min-width: 1300px) {
    #timeline-scroll {
      display: block;
    }
  }

  .rail-track {
    position: relative;
    height: 100%;
    width: 4px; /* increased from 2px */
  }

  .rail-line {
    position: absolute;
    inset: 0;
    background: rgba(231, 231, 216, 0.08);
    border-radius: 4px;
  }

  .rail-fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 0%;
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--color-orange, #ea4125) 90%, transparent),
      color-mix(in srgb, var(--color-orange, #ea4125) 15%, transparent)
    );
    border-radius: 4px;
    will-change: height;
  }

  .rail-traveler {
    position: absolute;
    left: 50%;
    top: 0%;
    transform: translate(-50%, -50%);
    width: 28px;
    height: 28px;
    will-change: top;
    pointer-events: none;
  }

  .traveler-glow {
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    background: var(--color-orange, #ea4125);
    filter: blur(11px);
    opacity: 0.65;
    animation: traveler-breathe 1.8s ease-in-out infinite;
  }

  .traveler-core {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 7px;
    height: 7px;
    border-radius: 9999px;
    background: var(--color-white, #ffffff);
    transform: translate(-50%, -50%);
    box-shadow: 0 0 14px 2px var(--color-orange, #ea4125);
  }

  @keyframes traveler-breathe {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.55;
    }
    50% {
      transform: scale(1.35);
      opacity: 0.85;
    }
  }

  .rail-tick {
    all: unset;
    position: absolute;
    left: 50%;
    width: 24px;
    height: 24px;
    transform: translate(-50%, -50%);
    cursor: pointer;
  }

  .rail-tick::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 3px;
    height: 3px;
    border-radius: 9999px;
    background: var(--color-eagle, #afac95);
    opacity: 0.5;
    transform: translate(-50%, -50%) scale(1);
    transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .rail-tick:hover::before {
    opacity: 1;
    transform: translate(-50%, -50%) scale(3.5);
    background: var(--color-white, #e7e7d8);
  }

  .rail-tick.active::before {
    opacity: 0;
  }
</style>

<script>
  const initTimelineScroll = () => {
    const track = document.getElementById("rail-track");
    const fill = document.getElementById("rail-fill");
    const traveler = document.getElementById("rail-traveler");
    const ticks = document.querySelectorAll<HTMLButtonElement>(
      "#timeline-scroll .rail-tick"
    );
    if (!track || !fill || !traveler || !ticks.length) return;

    const sections = Array.from(ticks)
      .map((btn) => {
        const id = btn.dataset.target;
        const el = id ? document.getElementById(id) : null;
        return el ? { btn, el } : null;
      })
      .filter(Boolean) as { btn: HTMLButtonElement; el: HTMLElement }[];

    if (!sections.length) return;

    const positionTicks = () => {
      const docHeight =
        document.documentElement.scrollHeight - window.innerHeight;
      if (docHeight <= 0) return;

      sections.forEach(({ btn, el }) => {
        const rect = el.getBoundingClientRect();
        const elTop = rect.top + window.scrollY;
        const pct = Math.min(100, Math.max(0, (elTop / docHeight) * 100));
        btn.style.top = `${pct}%`;
      });
    };

    let rafId: number | null = null;
    const updateProgress = () => {
      const docHeight =
        document.documentElement.scrollHeight - window.innerHeight;
      const scrolled = docHeight > 0 ? window.scrollY / docHeight : 0;
      const pct = Math.min(100, Math.max(0, scrolled * 100));

      fill.style.height = `${pct}%`;
      traveler.style.top = `${pct}%`;

      let activeIndex = -1;
      sections.forEach(({ el }, i) => {
        const rect = el.getBoundingClientRect();
        if (rect.top <= window.innerHeight * 0.5) activeIndex = i;
      });
      sections.forEach(({ btn }, i) => {
        btn.classList.toggle("active", i === activeIndex);
      });

      rafId = null;
    };

    const onScroll = () => {
      if (rafId === null) {
        rafId = requestAnimationFrame(updateProgress);
      }
    };

    sections.forEach(({ btn, el }) => {
      btn.addEventListener("click", () => {
        el.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", () => {
      positionTicks();
      updateProgress();
    });

    positionTicks();
    updateProgress();
  };

  document.addEventListener("DOMContentLoaded", initTimelineScroll);
  document.addEventListener("astro:page-load", initTimelineScroll);
</script>