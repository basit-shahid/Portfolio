---

const currentYear = new Date().getFullYear();

const navigationLinks = [
  { label: "Home", href: "#hero-section" },
  { label: "About", href: "#about" },
  { label: "Tech Stack", href: "#tech-stack-section" },
  { label: "Projects", href: "#projects" },
  { label: "Goals", href: "#goals" },
];

const socialLinks = [
  {
    name: "GitHub",
    url: "https://github.com/basit-shahid",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>`
  },
  {
    name: "LinkedIn",
    url: "https://linkedin.com/",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>`
  },
  {
    name: "Instagram",
    url: "https://www.instagram.com/abdulbasit_shahid?igsh=bXNkYnA5Y3hkMTlp",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>`
  },
  {
    name: "Facebook",
    url: "https://facebook.com/",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>`
  }
];
---

<footer class="relative border-t border-orange-500/20 bg-zinc-950 pt-24 pb-12 px-8 overflow-hidden">

  <!-- Pulsing top border trace -->
  <div class="footer-top-trace" aria-hidden="true"></div>

  <!-- Dynamic Ambient Backlight -->
  <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-orange-500/10 rounded-full blur-[140px] pointer-events-none z-0" />
  <div class="absolute top-0 left-1/4 w-[300px] h-[300px] bg-orange-600/5 rounded-full blur-[100px] pointer-events-none z-0" />

  <!-- Faint background grid -->
  <div class="footer-bg-grid" aria-hidden="true"></div>

  <!-- Giant watermark text -->
  <p class="footer-watermark" aria-hidden="true">ASTROMAX</p>

  <div class="max-w-7xl mx-auto relative z-10">

    

    <!-- Top Configuration Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 pb-16 border-b border-white/5">

      <!-- Brand & Status Beacon Column -->
      <div class="lg:col-span-5 flex flex-col items-start gap-5">
        <div class="flex items-center gap-3 mb-1">
          <span class="h-px w-10 bg-orange-500/70"></span>
          <span class="text-orange-500 text-xs font-bold tracking-[0.3em] uppercase">Connect</span>
        </div>
        <span class="text-white font-sans font-black uppercase tracking-widest text-3xl">
          A<span class="text-orange-500 animate-pulse">.</span>
        </span>
        <p class="text-zinc-400 text-base max-w-sm leading-relaxed font-medium">
          Designing and crafting high-performance, edge-optimized web applications with modern architecture and exceptional attention to detail.
        </p>
        <div class="flex items-center gap-3 px-4 py-2 rounded-xl border border-orange-500/20 bg-orange-500/5 text-xs font-mono text-orange-400 tracking-wide status-beacon">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-orange-500"></span>
          </span>
          <span>Open to specialized backend & system roles</span>
        </div>
      </div>

      <!-- Quick Nav Links Menu Container -->
      <div class="lg:col-span-3 lg:col-start-7 flex flex-col gap-4">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.886H3.848l4.912 3.57L6.848 18.34 12 14.77l5.152 3.57-1.912-5.884 4.912-3.57h-6.24L12 3z"/></svg>
          <p class="text-orange-500/90 font-mono text-xs uppercase tracking-[0.2em] font-bold">Navigation</p>
        </div>
        <ul class="flex flex-col gap-3 text-sm">
          {navigationLinks.map((link) => (
            <li>
              <a href={link.href} class="hover:text-orange-400 text-zinc-400 transition-colors duration-300 ease-out inline-flex items-center group/link js-smooth-scroll">
                <span class="w-0 group-hover/link:w-2 h-px bg-orange-500 mr-0 group-hover/link:mr-2 opacity-0 group-hover/link:opacity-100 transition-all duration-300"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick Contact Grid Base Component -->
      <div class="lg:col-span-3 flex flex-col gap-4">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <p class="text-orange-500/90 font-mono text-xs uppercase tracking-[0.2em] font-bold">Get In Touch</p>
        </div>
        <ul class="flex flex-col gap-4 text-sm text-zinc-400">
          <li class="flex flex-col">
            <span class="text-[10px] font-mono uppercase tracking-widest text-zinc-600">Direct Mail</span>
            <a href="mailto:basitdogar59@gmail.com" class="footer-mail-link hover:text-orange-400 text-zinc-300 transition-colors duration-300 mt-1 break-all font-medium">basitdogar59@gmail.com</a>
          </li>
          <li class="flex flex-col">
            <span class="text-[10px] font-mono uppercase tracking-widest text-zinc-600">Location Base</span>
            <span class="text-zinc-300 mt-1 font-medium inline-flex items-center gap-2">
              Lahore, Pakistan
              <span class="footer-live-dot" title="Local time-aware"></span>
            </span>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom Structural Layout -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-8 pt-10">

      <!-- Copyright & System Info Blocks -->
      <div class="text-xs font-mono text-zinc-500 order-2 sm:order-1 text-center sm:text-left">
        <p>&copy; {currentYear} ASTROMAX. All rights reserved.</p>
        <p class="mt-1.5 text-zinc-600">
          Engineered by <a href="https://github.com/basit-shahid" class="text-zinc-500 hover:text-orange-400 underline transition-colors duration-300 underline-offset-4 decoration-white/5">Abdul Basit Shahid</a>
        </p>
      </div>

      <!-- High-End Fluid Social Icons Bar Matrix -->
      <div class="flex items-center gap-3.5 order-1 sm:order-2">
        {socialLinks.map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            title={social.name}
            aria-label={`Visit my ${social.name}`}
            class="footer-social-icon p-3 rounded-xl border border-white/5 bg-zinc-900/40 text-zinc-400 hover:text-orange-500 hover:border-orange-500/40 hover:bg-orange-500/5 transition-all duration-300 flex items-center justify-center shadow-lg group relative overflow-hidden"
          >
            <span class="footer-social-glow"></span>
            <span class="block transition-transform duration-300 group-hover:scale-110 relative z-10" set:html={social.icon} />
          </a>
        ))}
      </div>

    </div>

  </div>
</footer>

<style>
  /* ---------- Top pulsing trace ---------- */
  .footer-top-trace {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(249,115,22,0.6), transparent);
    background-size: 200% 100%;
    animation: traceSweep 6s linear infinite;
    z-index: 1;
  }
  @keyframes traceSweep {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ---------- Background grid ---------- */
  .footer-bg-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(to right, rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 70% 70% at 50% 40%, black 30%, transparent 90%);
    z-index: 0;
  }

  /* ---------- Giant watermark ---------- */
  .footer-watermark {
    position: absolute;
    left: 50%;
    bottom: -4.5rem;
    transform: translateX(-50%);
    font-size: clamp(4rem, 16vw, 11rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255,255,255,0.05);
    white-space: nowrap;
    pointer-events: none;
    z-index: 0;
    user-select: none;
  }

  /* ---------- Back to top ---------- */
  .footer-back-to-top {
    position: absolute;
    top: -2.75rem;
    right: 2rem;
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(24,24,27,0.9);
    border: 1px solid rgba(249,115,22,0.25);
    color: rgb(253 186 116);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 10px 18px;
    border-radius: 999px;
    cursor: pointer;
    backdrop-filter: blur(10px);
    box-shadow: 0 8px 24px -8px rgba(0,0,0,0.6);
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    z-index: 20;
  }
  .footer-back-to-top:hover {
    transform: translateY(-3px);
    border-color: rgba(249,115,22,0.55);
    box-shadow: 0 12px 30px -6px rgba(234,88,12,0.35);
  }
  @media (max-width: 640px) {
    .footer-back-to-top {
      position: static;
      align-self: center;
      margin: 0 auto 2rem;
    }
  }

  /* ---------- Status beacon micro-shine ---------- */
  .status-beacon {
    position: relative;
    overflow: hidden;
  }
  .status-beacon::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(100deg, transparent 30%, rgba(255,255,255,0.06) 50%, transparent 70%);
    background-size: 200% 100%;
    animation: beaconShine 4s ease-in-out infinite;
  }
  @keyframes beaconShine {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ---------- Mail link underline sweep ---------- */
  .footer-mail-link {
    position: relative;
    display: inline-block;
  }
  .footer-mail-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1px;
    background: rgb(249 115 22 / 0.6);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
  }
  .footer-mail-link:hover::after {
    transform: scaleX(1);
  }

  .footer-live-dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: rgb(74 222 128);
    box-shadow: 0 0 6px rgba(74,222,128,0.7);
    animation: livePulse 2s ease-in-out infinite;
  }
  @keyframes livePulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* ---------- Social icons: magnetic-feel hover ---------- */
  .footer-social-icon {
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
                border-color 0.3s ease, background-color 0.3s ease;
  }
  .footer-social-icon:hover {
    transform: translateY(-4px) scale(1.06);
  }
  .footer-social-glow {
    position: absolute;
    inset: -30%;
    background: radial-gradient(circle, rgba(249,115,22,0.35), transparent 65%);
    opacity: 0;
    transition: opacity 0.35s ease;
    z-index: 0;
  }
  .footer-social-icon:hover .footer-social-glow {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-top-trace,
    .status-beacon::after,
    .footer-live-dot {
      animation: none !important;
    }
  }
</style>

<script>
  (() => {
    const btn = document.getElementById("footer-back-to-top");
    if (!btn) return;
    btn.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  })();
</script>