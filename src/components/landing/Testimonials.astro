---
// 1. FRONTMATTER - Retaining your core data structure unchanged
const techStack = [
  {
    name: "Laravel",
    iconUrl: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/laravel/laravel-original.svg",
    shouldInvert: false,
    description: "My core architecture suite. Used to build secure, robust APIs and service layers, focusing heavily on optimized database design, custom caching strategies, and reliable background job queues."
  },
  {
    name: "GitHub",
    iconUrl: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/github/github-original.svg",
    shouldInvert: true,
    description: "Crucial for workflow automation and source integrity. Beyond basic hosting, I emphasize semantic version control and continuous integration paths to streamline development pipeline speed."
  },
  {
    name: "WordPress",
    iconUrl: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/wordpress/wordpress-plain.svg",
    shouldInvert: true,
    description: "Leveraged for rapid deployment of heavy content structures. I bypass template assumptions to write optimized queries, clean headless integration layers, and performant local setups."
  },
  {
    name: "HTML & CSS",
    iconUrl: "https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/html5/html5-original.svg",
    shouldInvert: false,
    description: "The core canvas of the web interface layer. I prioritize structural, semantic markup and fast utility styling via Tailwind CSS to build layouts that render instantly under any regional connection constraint."
  }
];
---

<div id="tech-stack" class="max-w-7xl mx-auto px-8 mt-24 mb-10 text-left" data-framer-reveal>
  <p class="text-4xl md:text-5xl font-sans font-black tracking-tighter uppercase leading-none text-white lg:text-7xl">
    Tech <span class="text-orange-500">Stack</span><span class="text-orange-500">.</span>
  </p>
</div>

<!-- Grid container wrapping the cards with perspective context -->
<div class="max-w-7xl mx-auto gap-6 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 px-8 pb-16 card-perspective">
  {
    techStack.map((item, index) => (
      /* Outer Container protects the layout from frame reveal shifts */
      <div 
        class="w-full h-64 unique-card-container"
        data-framer-reveal
        data-delay={0.1 * index}
      >
        <!-- Inner Card handles the actual 3D turn -->
        <div class="flip-card-inner h-full w-full relative">
          
          <!-- ================= CARD FRONT: ONLY ICON ================= -->
          <div class="flip-card-front absolute inset-0 flex items-center justify-center p-5 border border-white/10 rounded-xl bg-zinc-900/40 backdrop-blur-md shadow-xl">
            <div class="w-24 h-24 flex items-center justify-center animate-pulse-slow">
              <img 
                src={item.iconUrl} 
                alt={`${item.name} icon`} 
                class={`w-20 h-20 object-contain ${item.shouldInvert ? 'inverted-icon' : ''}`}
                loading="lazy"
              />
            </div>
          </div>

          <!-- ================= CARD BACK: TEXT + ORANGE BG ================= -->
          <div class="flip-card-back absolute inset-0 flex flex-col justify-between p-5 rounded-xl bg-orange-500 shadow-[0_0_30px_5px_rgba(234,88,12,0.3)] border border-orange-500 text-zinc-950">
            <div class="w-full">
              <div class="flex items-center gap-4">
                <div class="p-2 bg-zinc-950 rounded-lg border border-white/10 shrink-0 flex items-center justify-center w-11 h-11 shadow-md">
                  <img 
                    src={item.iconUrl} 
                    alt={`${item.name} icon`} 
                    class="w-7 h-7 object-contain back-tech-icon"
                    style={item.shouldInvert ? "" : "filter: brightness(0) invert(1);"} 
                  />
                </div>
                
                <div class="flex flex-col justify-center">
                  <h3 class="text-sm sm:text-base font-black tracking-wide uppercase text-zinc-950">
                    {item.name}
                  </h3>
                  <span class="text-[10px] font-black tracking-widest text-orange-950/80 uppercase mt-0.5">
                    Core Engine
                  </span>
                </div>
              </div>

              <p class="text-[11px] sm:text-xs text-white-950 font-medium leading-relaxed tracking-wide mt-4 pt-3 border-t border-orange-700/40">
                {item.description}
              </p>
            </div>
          </div>

        </div>
      </div>
    ))
  }
</div>

<style>
  /* 1. Perspective Setup */
  .card-perspective {
    perspective: 1200px;
  }

  /* 2. 3D Engine Setup */
  .flip-card-inner {
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
    width: 100%;
    height: 100%;
  }

  /* Flip action when the outer element is hovered */
  .unique-card-container:hover .flip-card-inner {
    transform: rotateY(180deg);
  }

  /* Structural sharing with clean visibility clipping */
  .flip-card-front, .flip-card-back {
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
    width: 100%;
    height: 100%;
    border-radius: 0.75rem; /* Matches rounded-xl */
  }

  /* Base states layout layer separation */
  .flip-card-front {
    transform: rotateY(0deg);
    z-index: 2; /* Ensures icon shows up first */
  }

  .flip-card-back {
    transform: rotateY(180deg);
    z-index: 1;
  }

  /* 3. Utility Styles */
  @keyframes pulseSlow {
    0%, 100% { transform: scale(0.96); opacity: 0.9; }
    50% { transform: scale(1.04); opacity: 1; }
  }
  .animate-pulse-slow {
    animation: pulseSlow 3s ease-in-out infinite;
  }

  .inverted-icon {
    filter: invert(1) brightness(100%);
  }

  .back-tech-icon {
    filter: brightness(1) invert(1);
  }
</style>