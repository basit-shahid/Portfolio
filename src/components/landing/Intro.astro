---
import BgGrid from "@/components/assets/BgGrid.astro";
---

<section id="about" class="relative">
  <div class="px-8 pt-8 pb-4 relative">
    <p class="text-white font-black uppercase tracking-tighter lg:text-7xl text-xl">
      <span class="text-white">About</span> <span class="text-orange-500">ME.</span>
    </p>
  </div>
  
  <div class="px-8 pb-8 pt-2 text-white">
    <div class="relative max-w-5xl">
      
      <p 
        id="intro-ghost-text" 
        class="text-white-400 font-medium lg:text-2xl text-base normal-case leading-relaxed select-none pointer-events-none invisible"
      >
        Hey, I'm <span class="text-orange-500 font-bold">Abdul Basit Shahid</span> a Software Engineering student at <span class="text-orange-500 font-bold">COMSATS</span> Lahore Campus (Spring 2025 batch). I'm based in Lahore, Pakistan, and I spend most of my time geeking out over Data Structures & Algorithms, Object-Oriented Design, and building things end-to-end with Full-Stack Web Development and Backend Engineering. I like turning ideas into working code and figuring out how systems tick under the hood.
      </p>

      <p 
        id="intro-text" 
        class="absolute inset-0 text-white-400 font-medium lg:text-2xl text-base normal-case leading-relaxed opacity-0 transition-opacity duration-300"
      >
        Hey, I'm <span class="text-orange-500 font-bold">Abdul Basit Shahid</span> a Software Engineering student at <span class="text-orange-500 font-bold">COMSATS</span> Lahore Campus (Spring 2025 batch). I'm based in Lahore, Pakistan, and I spend most of my time geeking out over Data Structures & Algorithms, Object-Oriented Design, and building things end-to-end with Full-Stack Web Development and Backend Engineering. I like turning ideas into working code and figuring out how systems tick under the hood.<span id="intro-cursor" class="text-orange-500 ml-1 font-light inline-block animate-cursor-blink">|</span>
      </p>

    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const textContainer = document.getElementById("intro-text");
    const cursor = document.getElementById("intro-cursor");
    if (!textContainer || !cursor) return;

    // Cache the original layout
    const originalHTML = textContainer.innerHTML.replace(cursor.outerHTML, "").trim();
    
    // Make wrapper visible, clear content, display typing start
    textContainer.style.opacity = "1";
    textContainer.innerHTML = "";
    textContainer.appendChild(cursor);

    let currentIdx = 0;
    let isTag = false;
    const speed = 15;

    function typeWriter() {
      if (currentIdx < originalHTML.length) {
        const char = originalHTML[currentIdx];

        if (char === "<") isTag = true;
        if (char === ">") {
          isTag = false;
          currentIdx++;
          typeWriter();
          return;
        }

        currentIdx++;
        
        if (isTag) {
          typeWriter();
        } else {
          textContainer!.innerHTML = originalHTML.substring(0, currentIdx) + cursor!.outerHTML;
          setTimeout(typeWriter, speed);
        }
      } else {
        const finalCursor = document.getElementById("intro-cursor");
        if (finalCursor) {
          finalCursor.classList.add("animate-cursor-blink");
        }
      }
    }

    setTimeout(typeWriter, 400);
  });
</script>

<style>
  .animate-cursor-blink {
    animation: pulseCursor 0.8s steps(2, start) infinite;
  }

  @keyframes pulseCursor {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>