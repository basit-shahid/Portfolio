---
// Standalone High-Contrast Abstract Fluid Cyber-Wave Landscape Engine
---

<section id="hero-section" class="border-white/20 border-b pb-16 md:pb-24 relative overflow-hidden bg-zinc-950 min-h-[90vh] flex items-center">
  <div id="canvas-container" class="absolute inset-0 z-0 pointer-events-none opacity-95"></div>

  <div class="p-8 pt-12 md:pt-20 relative z-10 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-center relative">
      
      <div class="lg:col-span-2">
        <h1 class="text-white tracking-tighter font-black uppercase text-3xl lg:text-8xl select-none min-h-[160px] lg:min-h-[260px]">
          <span class="block" data-framer-reveal>HEY THERE,</span>
          
          <span class="block mt-3 lg:mt-6 text-white" data-framer-reveal data-delay="0.1">
            This is <span class="inline shadow-none"><span id="typewriter" class="animate-gradient-text bg-gradient-to-r from-orange-500 via-amber-400 to-orange-600 bg-[length:200%_auto] bg-clip-text text-transparent inline"></span><span id="cursor" class="text-orange-500 font-light ml-1 animate-pulse-fast inline-block select-none">|</span></span>
          </span>
        </h1>
      </div>

      <div class="flex justify-center lg:justify-end" data-framer-reveal data-delay="0.2">
        <div class="relative group w-64 h-64 lg:w-96 lg:h-96 overflow-hidden rounded-2xl border border-white/10 bg-zinc-900 shadow-2xl">
          <img 
            src="/ID.jpeg" 
            alt="Abdul Basit Shahid" 
            class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-500 ease-out"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent pointer-events-none"></div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  if (typeof window !== "undefined") {
    // Dynamic asset runtime loader to safeguard bundle compilation in Astro environments
    import('https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.module.js')
      .then((THREE) => {
        runHighContrastWaveEngine(THREE);
      })
      .catch((err) => console.error("Failed to build high-visibility particle context matrix", err));

    function runHighContrastWaveEngine(THREE) {
      const container = document.getElementById('canvas-container');
      if (!container) return;

      let scene, camera, renderer, particleSystem;
      let mouseX = 0, mouseY = 0;
      let targetX = 0, targetY = 0;
      const clock = new THREE.Clock();

      // Increased particle count density matrix for complete, dense section coverage
      const numParticlesX = 120;
      const numParticlesY = 85;
      const separation = 0.32;

      scene = new THREE.Scene();

      // Slightly lower FOV makes the foreground landscape much more prominent and sprawling
      camera = new THREE.PerspectiveCamera(50, container.clientWidth / container.clientHeight, 1, 1000);
      camera.position.set(0, 8, 20);
      camera.lookAt(0, -0.5, 0);

      renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
      renderer.setSize(container.clientWidth, container.clientHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      container.appendChild(renderer.domElement);

      // --- HIGH-DENSITY INTERACTIVE GLOWING PARTICLE LANDSCAPE ---
      const totalParticles = numParticlesX * numParticlesY;
      const positions = new Float32Array(totalParticles * 3);
      const colors = new Float32Array(totalParticles * 3);

      // Ultra High-Contrast Saturated Theme Colors
      const colorBlue = new THREE.Color(0x00a8ff);   // Vibrant electric cyber blue
      const colorOrange = new THREE.Color(0xff5722); // High-intensity bright neon orange
      const colorYellow = new THREE.Color(0xffd200); // Luminous starburst yellow

      let index = 0;
      for (let x = 0; x < numParticlesX; x++) {
        for (let y = 0; y < numParticlesY; y++) {
          // Align coordinate maps uniformly across the landscape expanse
          positions[index * 3] = (x * separation) - ((numParticlesX * separation) / 2);
          positions[index * 3 + 1] = 0; 
          positions[index * 3 + 2] = (y * separation) - ((numParticlesY * separation) / 2);

          // Advanced blending bands creating deep abstract color gradients across coordinates
          const ratioX = x / numParticlesX;
          const ratioY = y / numParticlesY;
          let finalColor = colorBlue.clone();

          // Mix colors diagonally to look natural and visually pleasant
          if (ratioX > 0.35 && ratioX < 0.7) {
            finalColor.lerp(colorOrange, (ratioX - 0.35) * 2.8);
          } else if (ratioX >= 0.7) {
            finalColor.lerp(colorYellow, (ratioX - 0.7) * 3.3);
          }
          
          // Inject minor ambient depth color modifiers based on Y vectors
          finalColor.addScalar(ratioY * 0.12);

          colors[index * 3] = finalColor.r;
          colors[index * 3 + 1] = finalColor.g;
          colors[index * 3 + 2] = finalColor.b;

          index++;
        }
      }

      const geometry = new THREE.BufferGeometry();
      geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
      geometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));

      // Custom high-contrast radial circle shader mask map
      const canvasNode = document.createElement('canvas');
      canvasNode.width = 32;
      canvasNode.height = 32;
      const ctx = canvasNode.getContext('2d');
      if (ctx) {
        const gradient = ctx.createRadialGradient(16, 16, 0, 16, 16, 16);
        gradient.addColorStop(0, 'rgba(255,255,255,1)');
        gradient.addColorStop(0.3, 'rgba(255,255,255,0.9)');
        gradient.addColorStop(1, 'rgba(255,255,255,0)');
        ctx.fillStyle = gradient;
        ctx.fillRect(0, 0, 32, 32);
      }
      const particleTexture = new THREE.CanvasTexture(canvasNode);

      const material = new THREE.PointsMaterial({
        size: 0.22, // Bigger size parameter ensures individual elements stay crisp and prominent
        vertexColors: true,
        map: particleTexture,
        transparent: true,
        opacity: 0.95,
        blending: THREE.AdditiveBlending, // Makes intersecting particle vertices glow brilliantly
        depthWrite: false
      });

      particleSystem = new THREE.Points(geometry, material);
      scene.add(particleSystem);

      // System Resize Handling Layout Mechanics
      window.addEventListener('resize', () => {
        camera.aspect = container.clientWidth / container.clientHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(container.clientWidth, container.clientHeight);
      });

      window.addEventListener('mousemove', (event) => {
        mouseX = (event.clientX - window.innerWidth / 2) / window.innerWidth;
        mouseY = (event.clientY - window.innerHeight / 2) / window.innerHeight;
      });

      // --- RUNTIME MATHEMATICAL WAVE ENGINE LOOP ---
      function animate() {
        requestAnimationFrame(animate);

        const elapsed = clock.getElapsedTime();
        const posArray = geometry.attributes.position.array;

        let pIndex = 0;
        for (let x = 0; x < numParticlesX; x++) {
          for (let y = 0; y < numParticlesY; y++) {
            // Amplified height waves ($Y$-vectors) for clear geometric ridges and depths
            const wave1 = Math.sin((x * 0.12) + (elapsed * 1.5)) * 1.4;
            const wave2 = Math.cos((y * 0.10) + (elapsed * 1.2)) * 0.9;
            const wave3 = Math.sin(((x + y) * 0.06) + (elapsed * 0.7)) * 0.5;

            posArray[pIndex * 3 + 1] = wave1 + wave2 + wave3;

            pIndex++;
          }
        }
        geometry.attributes.position.needsUpdate = true;

        // Smooth physics interpolation tracking mouse paths (Lag mechanics)
        targetX += (mouseX - targetX) * 0.04;
        targetY += (mouseY - targetY) * 0.04;

        // Subtle slow rolling baseline rotate sequence mixed with screen drift paths
        particleSystem.rotation.y = elapsed * 0.02 + (targetX * 0.15);
        particleSystem.position.z = targetY * 2.0;

        renderer.render(scene, camera);
      }

      animate();
    }


    // --- MECHANICAL TYPEWRITER & SCROLL ENGINE ---
    const targetText = "Abdul Basit Shahid";
    let lastCharIndex = 0;
    let lastScrollY = 0;
    let audioCtx: AudioContext | null = null;
    let isTicking = false;

    function initAudio() {
      if (!audioCtx) {
        const AudioContextClass = window.AudioContext || (window as any).webkitAudioContext;
        if (AudioContextClass) audioCtx = new AudioContextClass();
      }
      if (audioCtx && audioCtx.state === 'suspended') {
        audioCtx.resume();
      }
    }

    function playMechanicalStroke() {
      if (!audioCtx || audioCtx.state === 'suspended') return;

      try {
        const now = audioCtx.currentTime;
        const osc = audioCtx.createOscillator();
        const gainNode = audioCtx.createGain();
        const filter = audioCtx.createBiquadFilter();

        filter.type = "highpass";
        filter.frequency.setValueAtTime(650, now);

        osc.connect(gainNode);
        gainNode.connect(filter);
        filter.connect(audioCtx.destination);

        osc.type = "triangle";
        osc.frequency.setValueAtTime(1500 + Math.random() * 200, now);
        osc.frequency.exponentialRampToValueAtTime(400, now + 0.025);

        gainNode.gain.setValueAtTime(0.45, now);
        gainNode.gain.exponentialRampToValueAtTime(0.00001, now + 0.035);

        const clickOsc = audioCtx.createOscillator();
        const clickGain = audioCtx.createGain();

        clickOsc.type = "sine";
        clickOsc.frequency.setValueAtTime(3500, now);
        clickOsc.connect(clickGain);
        clickGain.connect(audioCtx.destination);

        clickGain.gain.setValueAtTime(0.08, now);
        clickGain.gain.exponentialRampToValueAtTime(0.00001, now + 0.008);

        osc.start(now);
        osc.stop(now + 0.04);
        clickOsc.start(now);
        clickOsc.stop(now + 0.01);
      } catch (e) {}
    }

    function handleScrollAnimation() {
      const typewriterElement = document.getElementById("typewriter");
      if (!typewriterElement) return;

      const currentScrollY = window.scrollY;
      const isScrollingDown = currentScrollY > lastScrollY;
      lastScrollY = currentScrollY;

      const maxScrollRunway = 350; 
      const scrollRatio = Math.min(Math.max(currentScrollY / maxScrollRunway, 0), 1);
      const nextCharIndex = Math.floor(scrollRatio * targetText.length);

      if (nextCharIndex !== lastCharIndex) {
        typewriterElement.textContent = targetText.substring(0, nextCharIndex);
        
        if (isScrollingDown && nextCharIndex > lastCharIndex) {
          playMechanicalStroke();
        }
        
        lastCharIndex = nextCharIndex;
      }

      isTicking = false;
    }

    function onScroll() {
      if (!isTicking) {
        requestAnimationFrame(handleScrollAnimation);
        isTicking = true;
      }
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("click", initAudio, { once: true });
    window.addEventListener("keydown", initAudio, { once: true });
    window.addEventListener("touchstart", initAudio, { once: true });

    handleScrollAnimation();
  }
</script>

<style>
  .animate-gradient-text {
    animation: shiftGradient 4s linear infinite;
  }

  .animate-pulse-fast {
    animation: pulseCursor 0.8s steps(2, start) infinite;
  }

  @keyframes shiftGradient {
    0%, 100% { background-position: 0% center; }
    50% { background-position: 100% center; }
  }

  @keyframes pulseCursor {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>